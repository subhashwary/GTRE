import os
import sys
from flask import Flask, send_from_directory

app = Flask(__name__)

# Fix for PyInstaller
if getattr(sys, 'frozen', False):
    BASE_DIR = sys._MEIPASS
else:
    BASE_DIR = os.path.dirname(os.path.abspath(__file__))

@app.route('/')
def serve_ui():
    return send_from_directory(BASE_DIR, 'index.html')
